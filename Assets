# Create directories
mkdir -p assets/css
mkdir -p assets/images/logo

# Create minimal CSS file
echo "/* The Divan and the Sword (TDS) Custom stylesheet v1.0.1 */" > assets/css/style.css

# Copy logo (available in memory) to the correct path
cp /path/to/tds-logo.png assets/images/logo/

# Verify files
ls -l assets/css/style.css
ls -l assets/images/logo/tds-logo.png

# Stage changes
git add assets/

# Commit with appropriate message
git commit -m "Add assets structure, stylesheet, and logo for v1.0.1"

# Push to repository
git push origin main
